function Badge({ label, color }) {
  return (
    <span style={{
      fontSize: 9, fontFamily: "monospace", fontWeight: 700,
      color, border: `1px solid ${color}`, borderRadius: 2,
      padding: "1px 5px", letterSpacing: 1
    }}>{label}</span>
  );
}

function CopyBtn({ text, label = "COPY" }) {
  const [copied, setCopied] = useState(false);
  const copy = () => {
    navigator.clipboard.writeText(text).then(() => {
      setCopied(true);
      setTimeout(() => setCopied(false), 1500);
    });
  };
  return (
    <button onClick={copy} style={{
      background: copied ? "#003322" : "#0a1a10",
      color: copied ? COLORS.accent : "#668877",
      border: `1px solid ${copied ? COLORS.accent : "#1a3325"}`,
      borderRadius: 3, padding: "3px 10px",
      fontSize: 10, fontFamily: "monospace", cursor: "pointer",
      transition: "all 0.2s"
    }}>{copied ? "✓ COPIED" : label}</button>
  );
}

function CodeBlock({ code, lang = "json" }) {
  return (
    <div style={{ position: "relative" }}>
      <pre style={{
        background: "#04080b", border: `1px solid ${COLORS.border}`,
        borderRadius: 4, padding: "10px 12px", margin: "8px 0",
        fontSize: 11, color: "#a0c4b0", overflowX: "auto",
        fontFamily: "monospace", lineHeight: 1.6, maxHeight: 280, overflowY: "auto"
      }}>{code}</pre>
      <div style={{ position: "absolute", top: 6, right: 6 }}>
        <CopyBtn text={code} />
      </div>
    </div>
  );
}

