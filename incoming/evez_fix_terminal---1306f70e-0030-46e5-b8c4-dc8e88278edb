                <div style={{ fontSize: 10, color: "#334455", marginTop: 3 }}>{p.desc}</div>
              </div>
              <Badge label="PENDING V3+V1 FIRST" color={COLORS.dim} />
            </div>
          ))}
        </div>
      )}

      {/* Footer */}
      <div style={{
        marginTop: 20, paddingTop: 12, borderTop: `1px solid ${COLORS.border}`,
        fontSize: 10, color: "#2a3a45", display: "flex", justifyContent: "space-between"
      }}>
        <span>EVEZ-OS PROTOCOL SPINE · PID 335</span>
        <span>protocol layer hardens first · mythic layer self-manages</span>
      </div>
    </div>
  );
}
