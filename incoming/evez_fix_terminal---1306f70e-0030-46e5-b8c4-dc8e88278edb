function StatusBar({ label, ok, notOk }) {
  const total = ok + notOk;
  const pct = total > 0 ? Math.round((ok / total) * 100) : 0;
  return (
    <div style={{ marginBottom: 16 }}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6 }}>
        <span style={{ fontSize: 10, color: COLORS.dim, fontFamily: "monospace" }}>{label}</span>
        <span style={{ fontSize: 10, fontFamily: "monospace" }}>
          <span style={{ color: COLORS.accent }}>{ok} FIXED</span>
          <span style={{ color: COLORS.dim }}> / </span>
          <span style={{ color: COLORS.danger }}>{notOk} BROKEN</span>
        </span>
      </div>
      <div style={{ height: 4, background: "#1a2330", borderRadius: 2, overflow: "hidden" }}>
        <div style={{
          height: "100%", width: `${pct}%`,
          background: `linear-gradient(90deg, ${COLORS.accent}, #00cc66)`,
          transition: "width 1s ease", borderRadius: 2
        }} />
      </div>
    </div>
  );
}

