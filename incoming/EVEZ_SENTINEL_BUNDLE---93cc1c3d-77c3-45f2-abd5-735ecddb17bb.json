            "jsCode": "\nconst health = $input.first().json;\n// Log to ledger\ntry {\n  await $fetch('https://evezos.app.n8n.cloud/webhook/evez-ledger', {\n    method: 'POST',\n    body: { event_type: 'WATCHDOG_ALERT', payload: health }\n  });\n} catch(e) {}\n\nreturn [{json:{\n  action: 'ALERT_LOGGED',\n  severity: health.overall_health,\n  blockers: health.unresolved_blockers,\n  remediation: health.remediation,\n  timestamp: health.timestamp\n}}];\n"
