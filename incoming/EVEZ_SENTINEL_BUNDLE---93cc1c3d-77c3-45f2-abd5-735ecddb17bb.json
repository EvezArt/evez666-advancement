          "parameters": {
            "jsCode": "\nconst systems = [\n  { name: 'CF_SENTINEL', env_var: 'CF_ACCOUNT_ID', required: true },\n  { name: 'CF_DNS',      env_var: 'CF_ZONE_ID',    required: true },\n  { name: 'PHOENIX_IP',  env_var: 'PHOENIX_BARE_METAL_IP', required: false },\n  { name: 'OPENAI',      env_var: 'OPENAI_API_KEY', required: true },\n  { name: 'SUPABASE',    env_var: 'SUPABASE_URL',   required: false },\n];\n\nconst results = systems.map(s => ({\n  system: s.name,\n  configured: !!($env[s.env_var] || ''),\n  required: s.required,\n  status: ($env[s.env_var] || '') ? 'GREEN' : (s.required ? 'RED' : 'YELLOW')\n}));\n\nconst reds = results.filter(r => r.status === 'RED');\nconst overall = reds.length === 0 ? 'GREEN' : reds.length <= 2 ? 'YELLOW' : 'RED';\n\n// Hash chain\nlet h = 5381;\nconst s = JSON.stringify({results, ts: new Date().toISOString()});\nfor(let i=0;i<s.length;i++){h=((h<<5)+h)+s.charCodeAt(i);h|=0;}\n\nreturn [{json:{\n  overall_health: overall,\n  systems: results,\n  unresolved_blockers: reds.map(r => r.system),\n  pid: 335,\n  timestamp: new Date().toISOString(),\n  entry_hash: 'sha_' + Math.abs(h).toString(16).padStart(16,'0'),\n  remediation: reds.length > 0 ? `Set env vars: ${reds.map(r=>r.system).join(', ')} in n8n Settings \u2192 Environment Variables` : 'All systems nominal'\n}}];\n"
          }
        },
