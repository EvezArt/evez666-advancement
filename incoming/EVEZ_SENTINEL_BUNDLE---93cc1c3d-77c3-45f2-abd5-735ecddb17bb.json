        },
        {
          "id": "W2C2",
          "name": "\ud83d\udd04 Diff IP vs Current",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            1120,
            0
          ],
          "parameters": {
            "jsCode": "\nconst dns = $input.item.json;\nconst existing = dns.result?.[0];\nconst targetIp = $('\ud83d\udd0d Detect Current IP').first().json.current_ip;\n\nreturn [{json:{\n  record_id: existing?.id || null,\n  existing_ip: existing?.content || null,\n  target_ip: targetIp,\n  domain: $('\ud83d\udd0d Detect Current IP').first().json.domain,\n  zone_id: $('\ud83d\udd0d Detect Current IP').first().json.zone_id,\n  token: $('\ud83d\udd0d Detect Current IP').first().json.token,\n  needs_update: existing?.content !== targetIp,\n  proxied: true,\n  ttl: 1\n}}];\n"
          }
        },
