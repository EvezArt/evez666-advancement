          "typeVersion": 2,
          "position": [
            280,
            110
          ],
          "parameters": {
            "jsCode": "\n// Pull current public IP of this n8n instance\n// In production this would query the Phoenix Oracle node\nconst envIp = $env.PHOENIX_BARE_METAL_IP || '';\nconst zoneId = $env.CF_ZONE_ID || '';\nconst token = $env.CF_API_TOKEN || '';\n\nif (!zoneId || !token) {\n  return [{json:{\n    skip: true,\n    reason: 'CF_ZONE_ID and CF_API_TOKEN env vars not set',\n    required_vars: ['CF_ZONE_ID', 'CF_API_TOKEN', 'CF_ACCOUNT_ID', 'PHOENIX_BARE_METAL_IP', 'EVEZ_SPINE_DOMAIN']\n  }}];\n}\n\nreturn [{json:{\n  skip: false,\n  current_ip: envIp || '0.0.0.0',\n  zone_id: zoneId,\n  token: token,\n  domain: $env.EVEZ_SPINE_DOMAIN || 'evez-spine.example.com',\n  timestamp: new Date().toISOString()\n}}];\n"
          }
        },
        {
          "id": "W2IF1",
          "name": "IP Configured?",
          "type": "n8n-nodes-base.if",
          "typeVersion": 2.2,
          "position": [
            560,
            110
