          "parameters": {
            "jsCode": "\nconst items = $input.all();\nconst item = items[0]?.json || {};\nlet h = 5381;\nconst s = JSON.stringify(item);\nfor(let i=0;i<s.length;i++){h=((h<<5)+h)+s.charCodeAt(i);h|=0;}\n\nreturn [{json:{\n  event: 'DNS_SYNC',\n  layer: 'L5_ORCHESTRATION',\n  domain: item.name || 'unknown',\n  ip: item.content || 'unknown',\n  proxied: true,\n  cf_masked: true,\n  pid: 335,\n  entry_hash: 'sha_' + Math.abs(h).toString(16).padStart(16,'0'),\n  timestamp: new Date().toISOString()\n}}];\n"
          }
        },
