        {
          "id": "W1C1",
          "name": "\ud83d\udd10 Build Sentinel Script",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            280,
            220
          ],
          "parameters": {
            "jsCode": "\n// Build canonical sentinel worker with env-injected config\nconst script = `addEventListener('fetch', event => {\n  event.respondWith(handleRequest(event.request))\n})\n\nasync function handleRequest(request) {\n  const CANONICAL_ID = \"05a7ef57d7c1699c3038363f2bbaa5ecc774ad7ce277e5ee923ec819e97d005f\";\n  const authHeader = request.headers.get('X-EVEZ-PID-AUTH');\n\n  if (authHeader !== CANONICAL_ID) {\n    return new Response(JSON.stringify({\n      error: 'Hopi Pahana Protocol: Unauthorized Access Detected.',\n      pid: 335,\n      timestamp: new Date().toISOString()\n    }), { status: 403, headers: { 'Content-Type': 'application/json' } });\n  }\n\n  const url = new URL(request.url);\n  url.hostname = self.PHOENIX_N8N_HOST || 'evezos.app.n8n.cloud';\n\n  const proxied = new Request(url.toString(), {\n    method: request.method,\n    headers: request.headers,\n    body: request.method !== 'GET' && request.method !== 'HEAD' ? request.body : undefined,\n    redirect: 'follow'\n  });\n\n  try {\n    const resp = await fetch(proxied);\n    return resp;\n  } catch(e) {\n    return new Response(JSON.stringify({ error: 'Phoenix unreachable', detail: e.message }), {\n      status: 502, headers: { 'Content-Type': 'application/json' }\n    });\n  }\n}`;\n\nconst accountId = $env.CF_ACCOUNT_ID || '';\nconst token = $env.CF_API_TOKEN || '';\nconst workerName = 'evez-sentinel-pid335';\nconst canonicalId = '05a7ef57d7c1699c3038363f2bbaa5ecc774ad7ce277e5ee923ec819e97d005f';\n\nif (!accountId || !token) {\n  throw new Error('CF_ACCOUNT_ID and CF_API_TOKEN env vars required. Set in n8n Settings \u2192 Environment Variables.');\n}\n\nreturn [{json:{\n  script,\n  accountId,\n  token,\n  workerName,\n  canonicalId,\n  deployUrl: `https://api.cloudflare.com/client/v4/accounts/${accountId}/workers/scripts/${workerName}`,\n  timestamp: new Date().toISOString(),\n  pid: 335\n}}];\n"
          }
        },
        {
          "id": "W1H1",
          "name": "\u2601\ufe0f Deploy Worker to CF Edge",
          "type": "n8n-nodes-base.httpRequest",
          "typeVersion": 4.4,
          "position": [
            560,
            220
          ],
          "parameters": {
            "method": "PUT",
            "url": "={{ $json.deployUrl }}",
            "sendHeaders": true,
            "headerParameters": {
              "parameters": [
                {
                  "name": "Authorization",
                  "value": "=Bearer {{ $json.token }}"
                },
                {
                  "name": "Content-Type",
                  "value": "text/javascript"
                }
              ]
            },
            "options": {
              "timeout": 30000
            },
            "sendBody": true,
            "contentType": "raw",
            "rawContentType": "text/javascript",
            "body": "={{ $json.script }}"
          }
        },
        {
          "id": "W1C2",
          "name": "\u2705 Verify Deployment",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            840,
            220
          ],
          "parameters": {
            "jsCode": "\nconst resp = $input.first().json;\nconst success = resp.success === true || resp.id !== undefined;\nconst ts = new Date().toISOString();\n\n// Build hash entry for ledger\nlet h = 5381;\nconst s = JSON.stringify({ts, success, worker: 'evez-sentinel-pid335'});\nfor(let i=0;i<s.length;i++){h=((h<<5)+h)+s.charCodeAt(i);h|=0;}\nconst hash = 'sha_' + Math.abs(h).toString(16).padStart(16,'0');\n\nreturn [{json:{\n  deployment_status: success ? 'DEPLOYED' : 'FAILED',\n  worker_name: 'evez-sentinel-pid335',\n  canonical_id: '05a7ef57d7c1699c3038363f2bbaa5ecc774ad7ce277e5ee923ec819e97d005f',\n  pid: 335,\n  layer: 'L4_EDGE',\n  timestamp: ts,\n  entry_hash: hash,\n  raw_response: resp\n}}];\n"
          }
        },
        {
          "id": "W1H2",
          "name": "\ud83d\udcca Health Check Worker",
          "type": "n8n-nodes-base.httpRequest",
          "typeVersion": 4.4,
          "position": [
            560,
            440
          ],
          "parameters": {
            "method": "GET",
            "url": "=https://api.cloudflare.com/client/v4/accounts/{{ $env.CF_ACCOUNT_ID }}/workers/scripts/evez-sentinel-pid335",
            "sendHeaders": true,
            "headerParameters": {
              "parameters": [
                {
                  "name": "Authorization",
                  "value": "=Bearer {{ $env.CF_API_TOKEN }}"
                }
              ]
            },
            "options": {
              "timeout": 30000
            }
          }
        },
        {
          "id": "W1C3",
          "name": "\ud83e\ude7a Parse Health",
          "type": "n8n-nodes-base.code",
          "typeVersion": 2,
          "position": [
            840,
            440
          ],
          "parameters": {
            "jsCode": "\nconst r = $input.first().json;\nreturn [{json:{\n  sentinel_alive: r.success !== false,\n  worker: 'evez-sentinel-pid335',\n  etag: r.etag || 'unknown',\n  checked_at: new Date().toISOString()\n}}];\n"
          }
        },
