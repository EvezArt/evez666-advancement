name: Enforce environment protection for deploy jobs & permissions
on:
  pull_request:
    paths: ['.github/workflows/**']
  push:
    branches: [ main ]
    paths: ['.github/workflows/**']
jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Check workflows for deploy steps without environment protection
        run: |
          set -euo pipefail
          files=$(git ls-files .github/workflows/*.yml .github/workflows/*.yaml || true)
          bad=0
          for f in $files; do
            if rg -n -i 'deploy' "$f" >/dev/null 2>&1; then
              if ! rg -n 'environment:' "$f" >/dev/null 2>&1; then
                echo "::error::$f contains deploy-related steps but lacks environment protection"
                bad=1
              fi
            fi
            if rg -n 'contents:\s*write|pull-requests:\s*write' "$f" >/dev/null 2>&1; then
              echo "::error::$f requests write-level permissions (contents/pull-requests). Please restrict to least privilege."
              bad=1
            fi
          done
          if [ $bad -ne 0 ]; then exit 1; fi
          echo "workflow checks passed"
