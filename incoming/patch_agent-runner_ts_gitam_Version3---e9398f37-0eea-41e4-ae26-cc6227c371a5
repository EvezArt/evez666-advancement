/**
 * Runner-level handler that receives agent action results and either proceeds or asks clarifying Qs.
 */
import { performExternalAction } from '../actions-placeholder';
import type { ActionResult } from '../agent/actions';
export async function handleAction(input: unknown, ctx: { id?: string } = {}) {
  const res: ActionResult = await performExternalAction(input, { idempotencyKey: ctx.id });
  if ((res as any).uncertaintyScore && (res as any).uncertaintyScore > 0.6) {
    return { needClarify: true, question: (res as any).clarifyingQuestion ?? 'Please clarify the request.' };
  }
  return { needClarify: false, result: (res as any).result };
}
