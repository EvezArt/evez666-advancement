name: Secrets Scanner (heuristic)
on:
  pull_request:
    paths: ['**']
  push:
    branches: [ main ]
    paths:
      - '**'
jobs:
  scan:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - name: Install ripgrep
        run: sudo apt-get update && sudo apt-get install -y ripgrep
      - name: Heuristic secrets scan
        run: |
          set -euo pipefail
          patterns=('VT_API_KEY' 'API_KEY' 'SECRET' 'TOKEN' 'PASSWORD' 'CIRCUIT_BYPASS_TOKEN' 'BYPASS_TOKEN' 'stripe' 'paypal' 'aws_secret_access_key')
          err=0
          for p in "${patterns[@]}"; do
            if rg -n --hidden -S --no-ignore -g '!.git' "$p" . || true; then
              echo "::error::Potential secret match: $p"
              err=1
            fi
          done
          if [ $err -ne 0 ]; then exit 1; fi
          echo "secrets-scan passed"
