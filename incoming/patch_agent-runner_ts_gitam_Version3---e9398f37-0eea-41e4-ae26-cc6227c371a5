/* Runner copy of toolClient (TypeScript) */
import type { RequestInit } from 'node-fetch';
const fetchImport = async () => (await import('node-fetch')).default;
const DEFAULT_TIMEOUT_MS = 8000;
function sleep(ms: number) { return new Promise((r) => setTimeout(r, ms)); }
export type ToolClientOptions = { timeoutMs?: number; maxRetries?: number; baseBackoff?: number; circuitThreshold?: number; circuitCooldownMs?: number; };
export type ToolClient = { call: (url: string, opts?: RequestInit, meta?: { idempotencyKey?: string }) => Promise<any>; _circuit: { failures: number; threshold: number; cooldownMs: number; openUntil: number }; };
export default function toolClient(opts: ToolClientOptions = {}): ToolClient {
  const timeoutMs = opts.timeoutMs ?? DEFAULT_TIMEOUT_MS;
  const maxRetries = opts.maxRetries ?? 3;
  const baseBackoff = opts.baseBackoff ?? 200;
  const cb = { failures: 0, threshold: opts.circuitThreshold ?? 6, cooldownMs: opts.circuitCooldownMs ?? 60_000, openUntil: 0 };
  async function call(url: string, fetchOpts: RequestInit = {}, meta: { idempotencyKey?: string } = {}) {
    const now = Date.now();
    if (cb.openUntil > now) { const err = new Error('circuit-breaker-open'); (err as any).code = 'CB_OPEN'; throw err; }
    const idempotencyKey = meta.idempotencyKey ?? null;
    let attempt = 0;
    const fetchFn = await fetchImport();
    while (attempt <= maxRetries) {
      attempt++;
      try {
        const headers = Object.assign({}, (fetchOpts.headers as Record<string,string>|undefined) ?? {});
        if (idempotencyKey) headers['Idempotency-Key'] = idempotencyKey;
        const controller = new AbortController();
        const timer = setTimeout(()=>controller.abort(), timeoutMs);
        const res = await fetchFn(url, Object.assign({}, fetchOpts, { signal: controller.signal, headers }));
        clearTimeout(timer);
        if (!res.ok) { const text = await res.text().catch(() => '<no-body>'); const err = new Error(`toolcall:${res.status} ${text}`); (err as any).code = `HTTP_${res.status}`; throw err; }
        cb.failures = 0;
        const text = await res.text().catch(() => '');
        try { return JSON.parse(text || '{}'); } catch { return {}; }
      } catch (err: any) {
        cb.failures = Math.min(cb.threshold+1, cb.failures + 1);
        if (cb.failures > cb.threshold) { cb.openUntil = Date.now() + cb.cooldownMs; }
        if (attempt > maxRetries) throw err;
        const backoff = baseBackoff * Math.pow(2, attempt-1) + Math.floor(Math.random()*100);
        await sleep(backoff);
        continue;
      }
    }
    throw new Error('unreachable-toolclient-exit');
  }
  return { call, _circuit: cb };
}
