name: EVEZ666 Autonomous Loop

on:
  schedule:
    # Run every 30 minutes (FIRE event sync interval)
    - cron: '*/30 * * * *'
  workflow_dispatch:
    inputs:
      mode:
        description: 'Run mode: full | memes | dev | scrape'
        required: false
        default: 'full'

env:
  OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
  TWITTER_BEARER_TOKEN: ${{ secrets.TWITTER_BEARER_TOKEN }}
  GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

jobs:
  # ── Twitter Intelligence Scrape ──────────────────────
  twitter-scrape:
    name: "Twitter Intelligence Scrape"
    runs-on: ubuntu-latest
    if: github.event.inputs.mode == 'full' || github.event.inputs.mode == 'scrape' || github.event_name == 'schedule'
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Install dependencies
        run: pip install requests openai pillow
      - name: Run Twitter scraper
        run: python bots/twitter_scraper.py
        continue-on-error: true
      - name: Commit corpus update
        run: |
          git config user.name "EVEZ-Bot"
          git config user.email "evez666@autonomous.bot"
          git add data/ || true
          git diff --staged --quiet || git commit -m "🔥 corpus update $(date -u +%Y-%m-%dT%H:%M:%SZ)"
          git push || true

  # ── Meme Generation ──────────────────────────────────
  meme-generation:
    name: "Messianic Meme Generation"
    runs-on: ubuntu-latest
    needs: twitter-scrape
    if: always() && (github.event.inputs.mode == 'full' || github.event.inputs.mode == 'memes' || github.event_name == 'schedule')
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Install dependencies
        run: pip install requests openai pillow
      - name: Pull latest corpus
        run: git pull || true
      - name: Generate meme batch
        run: python -c "
from agents.messiah_meme_agent import generate_meme_batch
import random
results = generate_meme_batch(
    count=3,
    fire_number=random.randint(460, 600),
    tau=round(random.uniform(10, 35), 1),
    v_value=round(random.uniform(0.75, 0.99), 3)
)
for r in results:
    print(f'Generated: {r[\"caption\"][:60]}...')
"
      - name: Commit memes
        run: |
          git config user.name "EVEZ-Bot"
          git config user.email "evez666@autonomous.bot"
          git add memes/output/ spine/ || true
          git diff --staged --quiet || git commit -m "🎭 meme batch $(date -u +%Y-%m-%dT%H:%M:%SZ) — topology decides"
          git push || true

  # ── Self-Development Cycle ────────────────────────────
  self-development:
    name: "Self-Development Cycle"
    runs-on: ubuntu-latest
    if: github.event.inputs.mode == 'full' || github.event.inputs.mode == 'dev'
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Install dependencies
        run: pip install requests openai
      - name: Run self-development cycle
        run: python agents/self_developer.py
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
      - name: Commit development decisions
        run: |
          git config user.name "EVEZ-Bot"
          git config user.email "evez666@autonomous.bot"
          git add data/ spine/ || true
          git diff --staged --quiet || git commit -m "🧠 self-dev cycle $(date -u +%Y-%m-%dT%H:%M:%SZ)"
          git push || true

  # ── Ecosystem Status Report ───────────────────────────
  status-report:
    name: "Ecosystem Status Report"
    runs-on: ubuntu-latest
    needs: [twitter-scrape, meme-generation]
    if: always()
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Install dependencies
        run: pip install requests openai
      - name: Generate status report
        run: python -c "
from agents.self_developer import generate_ecosystem_report
import pathlib
report = generate_ecosystem_report()
pathlib.Path('data/ecosystem_report.md').write_text(report)
print(report[:500])
"
      - name: Commit report
        run: |
          git config user.name "EVEZ-Bot"
          git config user.email "evez666@autonomous.bot"
          git add data/ecosystem_report.md || true
          git diff --staged --quiet || git commit -m "📊 ecosystem report $(date -u +%Y-%m-%dT%H:%M:%SZ)"
          git push || true
