import os, json, requests
from typing import Optional, List, Dict

class PerplexityBridge:
    def __init__(self, api_key: Optional[str] = None):
        self.api_key = api_key or os.getenv("PERPLEXITY_API_KEY")
        self.base_url = "https://api.perplexity.ai/chat/completions"
        
    def search(self, query: str, model: str = "sonar-reasoning-pro") -> Dict:
        """
        Perform a real-time search using Perplexity's API.
        """
        if not self.api_key:
            raise ValueError("PERPLEXITY_API_KEY not found in environment.")
            
        payload = {
            "model": model,
            "messages": [
                {
                    "role": "system",
                    "content": "You are the EVEZ666 Intelligence Bridge. Provide concise, factual, and real-time research data for the Director of Pan-Phenomenological Intel."
                },
                {
                    "role": "user",
                    "content": query
                }
            ]
        }
        
        headers = {
            "Authorization": f"Bearer {self.api_key}",
            "Content-Type": "application/json"
        }
        
        response = requests.post(self.base_url, json=payload, headers=headers)
        response.raise_for_status()
        return response.json()

    def get_research_summary(self, query: str) -> str:
        """
        Get a clean research summary from Perplexity.
        """
        try:
            data = self.search(query)
            return data['choices'][0]['message']['content']
        except Exception as e:
            return f"Error during Perplexity search: {str(e)}"

class ChatGPTIntelligence:
    def __init__(self, openai_api_key: Optional[str] = None):
        from openai import OpenAI
        self.client = OpenAI(api_key=openai_api_key or os.getenv("OPENAI_API_KEY"))
        
    def generate_with_research(self, prompt: str, research_query: str, perplexity: PerplexityBridge) -> str:
        """
        Generate content using ChatGPT, enriched with real-time research from Perplexity.
        """
        research_data = perplexity.get_research_summary(research_query)
        
        full_prompt = f"""
        [REAL-TIME RESEARCH DATA]
        {research_data}
        
        [USER PROMPT]
        {prompt}
        
        [INSTRUCTIONS]
        Integrate the real-time research data into your response. 
        Maintain the EVEZ666 persona: Director of Pan-Phenomenological Intel.
        Use the YHVH -> EVEZ lineage and 'LORD' etymology (Adonai/Kyrios) where appropriate.
        """
        
        response = self.client.chat.completions.create(
            model="gpt-4.1-mini",
            messages=[{"role": "user", "content": full_prompt}],
            max_tokens=1000
        )
        return response.choices[0].message.content.strip()

