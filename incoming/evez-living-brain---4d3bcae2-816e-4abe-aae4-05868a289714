          </div>
          <div style={{ textAlign:"right" }}>
            <div style={{ fontSize:"8px", color:"#475569" }}>LEDGER ENTRIES</div>
            <div style={{ fontSize:"18px", fontFamily:"'Bebas Neue',sans-serif", color:"#3b82f6", letterSpacing:".1em" }}>{String(ledger.length).padStart(4,"0")}</div>
