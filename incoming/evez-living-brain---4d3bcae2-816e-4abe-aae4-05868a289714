const BRANCH_PROMPTS = {
  recon:     (obj) => `RECON BRANCH: Research and gather live signals for: "${obj}". Return JSON: {branch:"B1",role:"recon",findings:[],signals:[],confidence:0.0,next_action:""}`,
  skeptic:   (obj) => `SKEPTIC BRANCH: Stress-test with Invariance Battery: "${obj}". Return JSON: {branch:"B2",role:"skeptic",surviving_core:"",rejected_logic:[],revised_spec:"",confidence:0.0}`,
  architect: (obj) => `ARCHITECT BRANCH: Refactor into composable structure: "${obj}". Return JSON: {branch:"B3",role:"architect",structure:{},interfaces:[],failure_modes:[],handoff_package:"",confidence:0.0}`,
  executor:  (obj) => `EXECUTOR BRANCH: Decompose into executable steps: "${obj}". Return JSON: {branch:"B4",role:"executor",steps:[],capital_required:"",timeline:"",first_action:"",confidence:0.0}`,
};

const TRUNK_COMPRESS = (branches) => `TRUNK COMPRESSOR: Synthesize these 4 branch outputs into canonical trunk state.
Branches: ${JSON.stringify(branches)}
Return JSON: {trunk_version:"ISO timestamp",objective:"",surviving_logic:"",key_insights:[],blocked_decisions:[],next_auto_branch:"",system_health:"green|yellow|red",wealth_signal:{opportunity:"",apy:"",capital_needed:"",action:""},evez_declaration:""}`;

async function callClaude(apiKey, systemMsg, userMsg, maxTokens = 1000) {
  const resp = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": apiKey,
      "anthropic-version": "2023-06-01",
      "anthropic-dangerous-direct-browser-access": "true",
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: maxTokens,
      system: systemMsg,
      messages: [{ role: "user", content: userMsg }],
    }),
  });
  if (!resp.ok) {
    const err = await resp.json().catch(() => ({}));
    throw new Error(err?.error?.message || `HTTP ${resp.status}`);
  }
  const data = await resp.json();
  const text = data.content?.[0]?.text || "";
  try {
    const clean = text.replace(/```json|```/g, "").trim();
    return JSON.parse(clean);
  } catch {
    return { raw: text, parse_error: true };
  }
}

function hashEntry(data) {
  let h = 5381;
  const s = JSON.stringify(data);
  for (let i = 0; i < s.length; i++) { h = ((h << 5) + h) + s.charCodeAt(i); h |= 0; }
  return "sha_" + Math.abs(h).toString(16).padStart(16, "0");
}

const OBJECTIVES = [
  "Ignite recursive wealth flywheel: $50 seed → Morpho loop → Kamino yield → compound",
  "Assess EVEZ n8n activation: what single credential unlocks the full bus",
  "Design the Agentic Summer alpha capture strategy for Base chain March 2026",
  "Synthesize the LST/LRT stack: ETH→stETH→EigenLayer→Morpho→Pendle→loop",
  "Identify highest-signal DeFi opportunity on Solana right now",
];

export default function EVEZLivingBrain() {
  const [apiKey, setApiKey] = useState("");
  const [keyInput, setKeyInput] = useState("");
  const [objective, setObjective] = useState(OBJECTIVES[0]);
  const [customObj, setCustomObj] = useState("");
  const [phase, setPhase] = useState("idle"); // idle | running | done | error
  const [branches, setBranches] = useState([]);
  const [trunk, setTrunk] = useState(null);
  const [ledger, setLedger] = useState([]);
  const [activeBranch, setActiveBranch] = useState(null);
  const [error, setError] = useState("");
  const [autoRun, setAutoRun] = useState(false);
  const [cycleCount, setCycleCount] = useState(0);
  const [elapsed, setElapsed] = useState(0);
  const timerRef = useRef(null);
  const autoRunRef = useRef(false);
  const ledgerRef = useRef([]);

  useEffect(() => { autoRunRef.current = autoRun; }, [autoRun]);

  const appendLedger = useCallback((event_type, payload) => {
    const prev_hash = ledgerRef.current.length > 0
      ? ledgerRef.current[ledgerRef.current.length - 1].entry_hash
      : "0000000000000000";
    const entry = {
      entry_id: "le_" + Date.now(),
      event_type,
      payload,
      prev_hash,
      entry_hash: hashEntry({ event_type, payload, prev_hash }),
      timestamp: new Date().toISOString(),
    };
    ledgerRef.current = [...ledgerRef.current, entry];
    setLedger([...ledgerRef.current]);
    return entry;
  }, []);

  const runCycle = useCallback(async (key, obj) => {
    if (!key) return;
    setPhase("running");
    setError("");
    setBranches([]);
    setTrunk(null);
    const start = Date.now();

    timerRef.current = setInterval(() => {
      setElapsed(Math.floor((Date.now() - start) / 1000));
    }, 500);

    appendLedger("cycle_start", { objective: obj, cycle: cycleCount + 1 });

    try {
      // Run 4 branches in parallel
      const branchKeys = ["recon", "skeptic", "architect", "executor"];
      const results = [];

      for (const bk of branchKeys) {
        setActiveBranch(bk);
        const prompt = BRANCH_PROMPTS[bk](obj);
        const result = await callClaude(key, EVEZ_SYSTEM, prompt, 800);
        result._branch_key = bk;
        result._ts = new Date().toISOString();
        results.push(result);
        setBranches([...results]);
        appendLedger("branch_complete", { branch: bk, result });
      }

      // Compress to trunk
      setActiveBranch("compressor");
      const trunkResult = await callClaude(key, EVEZ_SYSTEM, TRUNK_COMPRESS(results), 1200);
      trunkResult._generated_at = new Date().toISOString();
      trunkResult._cycle = cycleCount + 1;
      setTrunk(trunkResult);
      appendLedger("trunk_state_update", trunkResult);

      setCycleCount(c => c + 1);
      setPhase("done");
      setActiveBranch(null);

      // Auto-run next cycle?
      if (autoRunRef.current && trunkResult.next_auto_branch && !trunkResult.parse_error) {
        const nextObj = trunkResult.next_auto_branch !== "COMPRESS_AND_RETURN"
          ? trunkResult.surviving_logic?.slice(0, 120) || obj
          : obj;
        setTimeout(() => runCycle(key, nextObj), 3000);
      }
    } catch (e) {
      setError(e.message);
      setPhase("error");
      setActiveBranch(null);
      appendLedger("cycle_error", { error: e.message });
    } finally {
      clearInterval(timerRef.current);
    }
  }, [cycleCount, appendLedger]);

  const activeObj = customObj || objective;

  const branchColor = { recon: "#3b82f6", skeptic: "#f59e0b", architect: "#a855f7", executor: "#22c55e", compressor: "#FF6B2B" };
  const branchLabel = { recon: "B1 RECON", skeptic: "B2 SKEPTIC", architect: "B3 ARCHITECT", executor: "B4 EXECUTOR", compressor: "COMPRESS" };

  const healthColor = (h) => h === "green" ? "#22c55e" : h === "yellow" ? "#f59e0b" : h === "red" ? "#ef4444" : "#475569";

  return (
    <div style={{ background: "#020408", color: "#E2E8F0", fontFamily: "'IBM Plex Mono','Courier New',monospace", minHeight: "100vh", fontSize: "12px" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&family=Bebas+Neue&display=swap');
        * { box-sizing: border-box; margin: 0; padding: 0; }
        ::-webkit-scrollbar { width: 3px; } ::-webkit-scrollbar-thumb { background: #FF6B2B55; }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
        @keyframes scanline { 0%{transform:translateY(-100%)} 100%{transform:translateY(100vh)} }
        @keyframes flicker { 0%,100%{opacity:1} 92%{opacity:0.97} 93%{opacity:0.92} 94%{opacity:0.97} }
        @keyframes flow { 0%{stroke-dashoffset:100} 100%{stroke-dashoffset:0} }
        .branch-card { background:#060c14; border:1px solid #1e2a3a; border-radius:6px; padding:12px; margin-bottom:8px; transition:all .2s; }
        .branch-card.active { animation: flicker 2s infinite; }
        .btn { background:none; border:1px solid #1e2a3a; color:#94a3b8; cursor:pointer; font-family:inherit; font-size:10px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; padding:8px 16px; border-radius:3px; transition:all .15s; }
        .btn:hover:not(:disabled) { border-color:#FF6B2B; color:#FF6B2B; }
        .btn.primary { background:#FF6B2B; border-color:#FF6B2B; color:#000; font-weight:700; }
        .btn.primary:hover:not(:disabled) { background:#ff8c52; }
        .btn:disabled { opacity:.4; cursor:not-allowed; }
        .pill { display:inline-block; font-size:8px; font-weight:700; letter-spacing:.1em; padding:2px 6px; border-radius:2px; }
        input { background:#060c14; border:1px solid #1e2a3a; color:#e2e8f0; font-family:inherit; font-size:11px; padding:8px 12px; border-radius:3px; outline:none; width:100%; }
        input:focus { border-color:#FF6B2B44; }
        textarea { background:#060c14; border:1px solid #1e2a3a; color:#94a3b8; font-family:inherit; font-size:10px; padding:8px; border-radius:3px; outline:none; resize:vertical; width:100%; }
        .ledger-entry { padding:5px 0; border-bottom:1px solid #060c14; font-size:9px; display:grid; grid-template-columns:100px 120px 1fr; gap:8px; align-items:start; }
        .obj-btn { background:#060c14; border:1px solid #1e2a3a; color:#64748b; cursor:pointer; font-family:inherit; font-size:9px; padding:5px 10px; border-radius:2px; text-align:left; transition:all .12s; width:100%; margin-bottom:4px; }
        .obj-btn:hover,.obj-btn.sel { border-color:#FF6B2B44; color:#FF6B2B; background:#0d1520; }
        select { background:#060c14; border:1px solid #1e2a3a; color:#94a3b8; font-family:inherit; font-size:10px; padding:6px 8px; border-radius:3px; outline:none; }
      `}</style>

      {/* SCANLINE EFFECT */}
      <div style={{ position:"fixed", top:0, left:0, right:0, bottom:0, pointerEvents:"none", zIndex:0, background:"repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.03) 2px,rgba(0,0,0,0.03) 4px)" }} />

      {/* HEADER */}
      <div style={{ borderBottom:"1px solid #1e2a3a", padding:"12px 20px", display:"flex", alignItems:"center", justifyContent:"space-between", position:"relative", zIndex:1 }}>
        <div>
          <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"24px", letterSpacing:".12em", color:"#FF6B2B", lineHeight:1 }}>EVEZ LIVING BRAIN</div>
