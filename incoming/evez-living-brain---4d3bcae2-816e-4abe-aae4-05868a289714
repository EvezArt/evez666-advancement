          {phase === "idle" && cycleCount === 0 && (
            <div style={{ display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", height:"100%", opacity:.4 }}>
              <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"48px", color:"#1e2a3a", letterSpacing:".2em" }}>EVEZ</div>
              <div style={{ fontSize:"10px", color:"#334155", letterSpacing:".2em", marginTop:"8px" }}>PASTE API KEY → FIRE CYCLE → WATCH IT THINK</div>
            </div>
          )}
        </div>

        {/* RIGHT: LEDGER */}
        <div style={{ borderLeft:"1px solid #1e2a3a", padding:"16px", overflowY:"auto" }}>
          <div style={{ fontSize:"8px", color:"#475569", letterSpacing:".15em", marginBottom:"12px", display:"flex", justifyContent:"space-between" }}>
            <span>APPEND-ONLY LEDGER</span>
            <span style={{ color:"#3b82f6" }}>{ledger.length} ENTRIES</span>
          </div>

          {ledger.length === 0 && (
            <div style={{ fontSize:"9px", color:"#1e2a3a", textAlign:"center", marginTop:"40px" }}>// awaiting first event</div>
          )}

          {[...ledger].reverse().map((entry, i) => (
            <div key={entry.entry_id} className="ledger-entry">
              <div style={{ fontSize:"8px", color:"#334155" }}>{entry.timestamp.slice(11,23)}</div>
              <div>
                <span className="pill" style={{
                  background: entry.event_type.includes("error")?"#ef444422":entry.event_type.includes("trunk")?"#FF6B2B22":entry.event_type.includes("branch")?"#a855f722":"#3b82f622",
                  color: entry.event_type.includes("error")?"#ef4444":entry.event_type.includes("trunk")?"#FF6B2B":entry.event_type.includes("branch")?"#a855f7":"#3b82f6",
                }}>
                  {entry.event_type.replace(/_/g," ").toUpperCase()}
                </span>
              </div>
              <div>
                <div style={{ fontSize:"8px", color:"#334155", fontFamily:"monospace" }}>{entry.entry_hash}</div>
                <div style={{ fontSize:"7px", color:"#1e2a3a" }}>prev: {entry.prev_hash.slice(0,16)}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}
