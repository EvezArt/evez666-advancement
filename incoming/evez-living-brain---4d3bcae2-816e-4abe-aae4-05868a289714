            {!apiKey && <div style={{ fontSize:"8px", color:"#334155", marginTop:"4px" }}>console.anthropic.com → API Keys → create key → paste above</div>}
          </div>

          {/* OBJECTIVE */}
          <div>
            <div style={{ fontSize:"8px", color:"#475569", letterSpacing:".12em", marginBottom:"6px" }}>TRUNK OBJECTIVE</div>
            {OBJECTIVES.map((o, i) => (
              <button key={i} className={`obj-btn${objective===o&&!customObj?" sel":""}`} onClick={() => { setObjective(o); setCustomObj(""); }}>
                {o.slice(0, 65)}{o.length > 65 ? "…" : ""}
              </button>
            ))}
            <textarea rows={3} placeholder="Custom objective..." value={customObj} onChange={e => setCustomObj(e.target.value)} style={{ marginTop:"4px" }} />
          </div>

          {/* CONTROLS */}
          <div style={{ display:"flex", flexDirection:"column", gap:"6px" }}>
            <button className="btn primary" disabled={!apiKey || phase==="running"} onClick={() => runCycle(apiKey, activeObj)}>
              {phase==="running" ? `⟳ RUNNING B${branches.length+1}/4…` : "▶ FIRE TRUNK CYCLE"}
            </button>
            <div style={{ display:"flex", gap:"6px" }}>
              <button className="btn" style={{ flex:1, fontSize:"9px" }} disabled={!apiKey || phase==="running"}
                onClick={() => { setAutoRun(a => { const n=!a; autoRunRef.current=n; return n; }) }}>
                {autoRun ? "⏸ STOP AUTO" : "∞ AUTO-RUN"}
              </button>
              <button className="btn" style={{ fontSize:"9px", padding:"8px" }} onClick={() => { setBranches([]); setTrunk(null); setError(""); setPhase("idle"); setCycleCount(0); setElapsed(0); setLedger([]); ledgerRef.current=[]; }}>
                ✕
              </button>
            </div>
          </div>

          {error && (
            <div style={{ background:"#1a0000", border:"1px solid #ef444433", borderRadius:"4px", padding:"10px", fontSize:"10px", color:"#ef4444" }}>
              ⚠ {error}
            </div>
          )}

          {/* BRANCH PROGRESS */}
          <div>
            <div style={{ fontSize:"8px", color:"#475569", letterSpacing:".12em", marginBottom:"8px" }}>BRANCH PIPELINE</div>
            {["recon","skeptic","architect","executor","compressor"].map(bk => {
              const done = bk === "compressor" ? trunk !== null : branches.some(b => b._branch_key === bk);
              const active = activeBranch === bk;
              const c = branchColor[bk];
              return (
                <div key={bk} style={{ display:"flex", alignItems:"center", gap:"8px", padding:"5px 0", borderBottom:"1px solid #060c14" }}>
                  <div style={{ width:"20px", height:"20px", borderRadius:"50%", border:`1.5px solid ${done?c:"#1e2a3a"}`, background:done?c+"22":"none", display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0, animation:active?"pulse 0.8s infinite":"none" }}>
                    {done ? <span style={{ fontSize:"9px", color:c }}>✓</span> : active ? <span style={{ fontSize:"9px", color:c, animation:"pulse .5s infinite" }}>●</span> : null}
                  </div>
                  <span style={{ fontSize:"9px", color:done?c:active?c:"#334155", fontWeight:done||active?"700":"400" }}>{branchLabel[bk]}</span>
                </div>
              );
            })}
          </div>
        </div>

        {/* CENTER: LIVE OUTPUT */}
        <div style={{ overflowY:"auto", padding:"16px", display:"flex", flexDirection:"column", gap:"12px" }}>

          {/* TRUNK STATE */}
          {trunk && (
            <div style={{ background:"#060c14", border:"1px solid #FF6B2B33", borderRadius:"6px", padding:"16px" }}>
              <div style={{ display:"flex", alignItems:"center", gap:"10px", marginBottom:"12px" }}>
                <div style={{ fontFamily:"'Bebas Neue',sans-serif", fontSize:"16px", letterSpacing:".1em", color:"#FF6B2B" }}>TRUNK STATE</div>
                <span className="pill" style={{ background:healthColor(trunk.system_health)+"22", color:healthColor(trunk.system_health), border:`1px solid ${healthColor(trunk.system_health)}44` }}>
                  {(trunk.system_health || "unknown").toUpperCase()}
                </span>
                <span style={{ fontSize:"9px", color:"#334155", marginLeft:"auto" }}>cycle {trunk._cycle} · {trunk._generated_at?.slice(11,19)}</span>
              </div>

              {trunk.evez_declaration && (
                <div style={{ fontSize:"13px", color:"#e2e8f0", fontStyle:"italic", borderLeft:"2px solid #FF6B2B", paddingLeft:"12px", marginBottom:"12px", lineHeight:"1.6" }}>
                  "{trunk.evez_declaration}"
                </div>
              )}

              {trunk.surviving_logic && (
                <div style={{ marginBottom:"12px" }}>
                  <div style={{ fontSize:"8px", color:"#475569", letterSpacing:".1em", marginBottom:"6px" }}>SURVIVING LOGIC</div>
                  <div style={{ fontSize:"10px", color:"#94a3b8", lineHeight:"1.7" }}>{trunk.surviving_logic}</div>
                </div>
              )}

              {trunk.wealth_signal && (
                <div style={{ background:"#001a0e", border:"1px solid #22c55e33", borderRadius:"4px", padding:"12px", marginBottom:"12px" }}>
                  <div style={{ fontSize:"8px", color:"#22c55e", letterSpacing:".12em", marginBottom:"8px" }}>💰 WEALTH SIGNAL</div>
                  <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:"8px" }}>
                    {["opportunity","apy","action"].map(k => trunk.wealth_signal[k] && (
                      <div key={k}>
                        <div style={{ fontSize:"8px", color:"#475569", textTransform:"uppercase" }}>{k}</div>
                        <div style={{ fontSize:"10px", color:"#22c55e", fontWeight:"700", marginTop:"2px" }}>{trunk.wealth_signal[k]}</div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {trunk.key_insights?.length > 0 && (
                <div style={{ marginBottom:"12px" }}>
                  <div style={{ fontSize:"8px", color:"#475569", letterSpacing:".1em", marginBottom:"6px" }}>KEY INSIGHTS</div>
                  {trunk.key_insights.map((ins, i) => (
                    <div key={i} style={{ fontSize:"10px", color:"#94a3b8", padding:"4px 0", borderBottom:"1px solid #0a0f1a", display:"flex", gap:"8px" }}>
                      <span style={{ color:"#FF6B2B", flexShrink:0 }}>{i+1}.</span>{ins}
                    </div>
                  ))}
                </div>
              )}

              {trunk.blocked_decisions?.length > 0 && (
                <div style={{ background:"#1a0800", border:"1px solid #f59e0b33", borderRadius:"4px", padding:"10px" }}>
                  <div style={{ fontSize:"8px", color:"#f59e0b", letterSpacing:".1em", marginBottom:"6px" }}>⚠ BLOCKED — HUMAN REQUIRED</div>
                  {trunk.blocked_decisions.map((d, i) => (
                    <div key={i} style={{ fontSize:"9px", color:"#92400e", padding:"2px 0" }}>→ {d}</div>
                  ))}
                </div>
              )}
            </div>
          )}

          {/* BRANCH RESULTS */}
          {branches.map((b, i) => {
            const bk = b._branch_key;
            const c = branchColor[bk] || "#64748b";
            return (
              <div key={i} className={`branch-card${activeBranch===bk?" active":""}`} style={{ borderColor: c+"44" }}>
                <div style={{ display:"flex", alignItems:"center", gap:"8px", marginBottom:"8px" }}>
                  <span className="pill" style={{ background:c+"22", color:c, border:`1px solid ${c}44` }}>{branchLabel[bk]}</span>
                  {b.confidence !== undefined && (
                    <div style={{ height:"3px", flex:1, background:"#1e2a3a", borderRadius:"2px", overflow:"hidden" }}>
                      <div style={{ height:"100%", width:`${(b.confidence||0)*100}%`, background:c, transition:"width .5s" }} />
                    </div>
                  )}
                  <span style={{ fontSize:"8px", color:"#334155" }}>{b.confidence !== undefined ? `${Math.round((b.confidence||0)*100)}%` : ""}</span>
                </div>
                {b.parse_error ? (
                  <div style={{ fontSize:"9px", color:"#94a3b8", lineHeight:"1.6" }}>{b.raw?.slice(0,300)}</div>
                ) : (
                  <div style={{ fontSize:"9px", color:"#64748b", lineHeight:"1.6" }}>
                    {bk==="recon" && b.findings?.map((f,j) => <div key={j} style={{paddingLeft:"8px",borderLeft:`2px solid ${c}44`}}>{f}</div>)}
                    {bk==="skeptic" && <><div style={{color:"#22c55e",marginBottom:"4px"}}>✓ {b.surviving_core}</div>{b.rejected_logic?.map((r,j)=><div key={j} style={{color:"#ef4444"}}>✗ {r}</div>)}</>}
                    {bk==="architect" && <><div style={{color:"#94a3b8",marginBottom:"4px"}}>{b.handoff_package}</div>{b.failure_modes?.map((f,j)=><div key={j} style={{color:"#f59e0b"}}>⚠ {f}</div>)}</>}
