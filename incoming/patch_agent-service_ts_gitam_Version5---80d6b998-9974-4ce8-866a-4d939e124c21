/**
 * Agent action API (TypeScript)
 * Exported performExternalAction returns:
 *  { result: any | null, uncertaintyScore: number, clarifyingQuestion?: string, error?: string }
 *
 * This file is a scaffold demonstrating attaching uncertainty metadata to actions
 * and returning a clarifying question when uncertainty is high.
 */

import toolClientFactory from '../lib/toolClient';

export type ActionResult =
  | { result: any; uncertaintyScore: number }
  | { result: null; uncertaintyScore: number; clarifyingQuestion?: string; error?: string };

const toolClient = toolClientFactory({ timeoutMs: 5000, maxRetries: 2 });

export async function performExternalAction(input: unknown, opts: { idempotencyKey?: string } = {}): Promise<ActionResult> {
  const idKey = opts.idempotencyKey ?? `act-${Date.now()}-${Math.floor(Math.random() * 1000)}`;
  try {
    const raw = await toolClient.call('https://example-external.local/do', {
      method: 'POST',
      body: JSON.stringify({ input }),
      headers: { 'Content-Type': 'application/json' }
    }, { idempotencyKey: idKey });

    // If the external service returns a confidence in [0,1], derive uncertainty
    const confidence = typeof raw?.confidence === 'number' ? Math.max(0, Math.min(1, raw.confidence)) : undefined;
    const uncertainty = confidence !== undefined ? 1 - confidence : 0.3;

    if (uncertainty > 0.6) {
      // Return clarifying question to surface to user/human-in-loop
      return { result: null, uncertaintyScore: uncertainty, clarifyingQuestion: 'Can you specify the target environment (staging/production)?' };
    }

    return { result: raw, uncertaintyScore: uncertainty };
  } catch (err: any) {
    return { result: null, uncertaintyScore: 1.0, error: err?.message ?? String(err) };
  }
}
