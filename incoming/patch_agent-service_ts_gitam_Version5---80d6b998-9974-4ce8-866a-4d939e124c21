#!/usr/bin/env bash
set -euo pipefail
REPO="$1"
if [ -z "$REPO" ]; then echo "Usage: $0 owner/repo"; exit 2; fi
echo "Locking down $REPO"
gh api -X PUT "repos/${REPO}/actions/permissions" -f '{"permissions":{"contents":"read"}}' || true
ids=$(gh api "repos/${REPO}/actions/workflows" --jq '.workflows[].id' || true)
for id in $ids; do gh api -X PUT "repos/${REPO}/actions/workflows/${id}/disable" || true; done
gh secret list --repo "${REPO}" || true
gh issue create --repo "${REPO}" --title "EMERGENCY: Actions lockdown applied — review required" --body "Emergency lockdown applied. Rotate tokens & review workflows." || true
echo "Done: $REPO"