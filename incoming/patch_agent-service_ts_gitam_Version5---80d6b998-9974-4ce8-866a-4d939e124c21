/**
 * Simple plan checkpointing and rollback hooks (TypeScript)
 * In-memory implementation for demo/tests. Replace with durable storage in production.
 */

export type Step = {
  commit: () => Promise<void>;
  rollback?: () => Promise<void>;
  meta?: Record<string, unknown>;
};

type PlanState = {
  stepIndex: number;
  steps: Step[];
};

const checkpoints = new Map<string, PlanState>();

export function newPlan(planId: string) {
  checkpoints.set(planId, { stepIndex: 0, steps: [] });
  return planId;
}

export function registerStep(planId: string, step: Step) {
  const p = checkpoints.get(planId);
  if (!p) throw new Error('plan-not-found');
  p.steps.push(step);
}

export async function runPlan(planId: string): Promise<{ status: 'ok' } | { status: 'failed'; error: string }> {
  const p = checkpoints.get(planId);
  if (!p) throw new Error('plan-not-found');
  try {
    for (let i = p.stepIndex; i < p.steps.length; i++) {
      const s = p.steps[i];
      p.stepIndex = i;
      await s.commit();
    }
    checkpoints.delete(planId);
    return { status: 'ok' };
  } catch (err: any) {
    // rollback committed steps in reverse order
    for (let j = p.stepIndex; j >= 0; j--) {
      const step = p.steps[j];
      if (step && step.rollback) {
        try {
          // eslint-disable-next-line no-await-in-loop
          await step.rollback();
        } catch (_) {
          // swallow rollback errors
        }
      }
    }
    checkpoints.delete(planId);
    return { status: 'failed', error: err?.message ?? String(err) };
  }
}
