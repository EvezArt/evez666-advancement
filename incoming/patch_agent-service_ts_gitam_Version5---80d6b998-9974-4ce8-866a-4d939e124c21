import { newPlan, registerStep, runPlan } from '../src/agent/plan';

describe('plan checkpointing and rollback', () => {
  test('commits steps and rolls back on failure', async () => {
    const planId = newPlan('test-plan-1');
    const events: string[] = [];
    registerStep(planId, { commit: async () => { events.push('c1'); }, rollback: async () => { events.push('r1'); }});
    registerStep(planId, { commit: async () => { events.push('c2'); throw new Error('fail-step-2'); }, rollback: async () => { events.push('r2'); }});
    const res = await runPlan(planId);
    expect(res.status).toBe('failed');
    expect(events).toEqual(expect.arrayContaining(['c1','c2','r2','r1']));
  });
});
