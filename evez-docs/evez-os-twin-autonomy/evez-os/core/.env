# EVEZ-OS Core Configuration
# Immutable Witness Computational Network

## Runtime Settings
LATENCY_THRESHOLD_MS=20
EXECUTION_MODE=TRUNK_BRANCH_AUTOMATION
RULE_2_REFUSAL_ENABLED=true
AUTO_BRANCH_RETURN=true
AUTO_SUMMARY_INTERVAL=4
PROVENANCE_LOGGING=STRICT
HUMAN_APPROVAL_MODE=BOUNDARY_ONLY
LEDGER_SYNC_INTERVAL_MS=500

## External Services
EVEZ_RPC_URL=https://private-rpc.getblock.io/[ID]
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/evez-fire
BASE44_OPERATOR_ID=[ID]

## Identity & Provenance
IDENTITY_ROOT_HASH=[EVEZ_CONSTITUTION_HASH]
SKEPTIC_ENTITY_PATH=./local/surething/skeptic_entity.py

## OpenClaw Integration
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_RECURSION_DEPTH=INFINITY
SPECULATIVE_EXECUTION_THREADS=256
TRUNK_SYNC_MODE=NON_BLOCKING
CAPTURE_THRESHOLD=0.01_USD