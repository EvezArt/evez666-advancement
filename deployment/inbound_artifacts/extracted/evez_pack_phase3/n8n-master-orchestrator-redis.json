    {
      "parameters": {
        "jsCode": "const normalized = $('Normalize Input').first().json;\nconst result = $json.output ?? $json;\nconst ok = result.status === 'completed' || result.status === 'partial_failure';\nconst now = new Date().toISOString();\nconst finalPayload = {\n  ok,\n  run_id: result.run_id || normalized.run_id,\n  status: result.status || 'failed',\n  summary: result.summary || 'No summary returned by planner.',\n  tool_actions: result.tool_actions || [],\n  errors: result.errors || [],\n  retry_scheduled: false,\n  next_action: result.next_action || 'none',\n  updated_at: now,\n  attempt: normalized.attempt,\n  route: normalized.route,\n  isWebhookExecution: normalized.isWebhookExecution,\n  original_request: normalized.raw_input\n};\nreturn [{ json: finalPayload }];"
      },
