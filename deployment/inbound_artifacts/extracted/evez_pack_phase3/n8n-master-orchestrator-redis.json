      "parameters": {
        "jsCode": "const input = $json || {};\nconst repoRaw = String(input.github_repo || input.repo || '{{GITHUB_REPO}}');\nconst repoParts = repoRaw.includes('/') ? repoRaw.split('/') : ['owner', repoRaw];\nconst runId = input.run_id || ('run_' + Date.now());\nconst attempt = Number(input.attempt || 0);\nconst route = input._route || 'orchestrate';\nreturn [{ json: {\n  route,\n  isWebhookExecution: Boolean(input._isWebhookExecution),\n  run_id: runId,\n  source: input.source || route,\n  attempt,\n  task: input.task || input.objective || 'Autonomous maintenance sweep',\n  objective: input.objective || input.task || 'Autonomous maintenance sweep',\n  context: input.context || {},\n  browser: {\n    required: route === 'browser' || Boolean(input.force_browser || input.browser?.required || input.requires_browser),\n    task: input.browser?.task || input.browser_task || input.task || 'Autonomous browser task',\n    llm: input.browser?.llm || 'gpt-4o',\n    maxSteps: Number(input.browser?.maxSteps || input.browser_maxSteps || 20)\n  },\n  github: {\n    owner: input.github?.owner || repoParts[0],\n    repoName: input.github?.repoName || repoParts[1],\n    issue: input.github?.issue || {},\n    commit: input.github?.commit || {},\n    workflow: input.github?.workflow || {}\n  },\n  force_github: Boolean(input.force_github),\n  raw_input: input\n} }];\n"
