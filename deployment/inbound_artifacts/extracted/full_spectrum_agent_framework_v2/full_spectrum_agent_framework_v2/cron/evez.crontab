SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

*/5 * * * * cd __ROOT__ && python3 scripts/daemon_runner.py --config config/system.json --mode daemon_pass >> logs/cron.log 2>&1
*/15 * * * * cd __ROOT__ && python3 scripts/daemon_runner.py --config config/system.json --mode maintenance_pass >> logs/cron.log 2>&1
0 * * * * cd __ROOT__ && python3 scripts/daemon_runner.py --config config/system.json --mode hourly_chronicle >> logs/cron.log 2>&1
15 0 * * * cd __ROOT__ && python3 scripts/daemon_runner.py --config config/system.json --mode daily_report >> logs/cron.log 2>&1
30 1 * * 0 cd __ROOT__ && python3 scripts/daemon_runner.py --config config/system.json --mode weekly_archive >> logs/cron.log 2>&1
